<div class="deferred-block deferred-block--notification" data-block="notification-bell">
    <div class="notification-bell" data-notification-bell>
        <span class="notification-bell__icon">🔔</span>
        {% if count > 0 %}
        <span class="notification-bell__badge" data-notification-count>{{ count }}</span>
        {% endif %}
    </div>
    {% if notifications|length > 0 %}
    <ul class="notification-list">
        {% for notification in notifications %}
        <li class="notification-list__item notification-list__item--{{ notification.level|default('info') }}">
            {{ notification.message }}
        </li>
        {% endfor %}
    </ul>
    {% endif %}
</div>

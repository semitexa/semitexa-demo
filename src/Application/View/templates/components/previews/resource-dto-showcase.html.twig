<div class="preview-card preview-card--layered">
  <p class="preview-card__eyebrow">Presentation Boundary</p>
  <h3 class="preview-card__title">Resource DTOs break the fake separation between data and templates</h3>
  <p class="preview-card__summary">
    This is not theory. The handler shapes one response object, and every template, partial, and layout reads from that
    explicit contract instead of improvising with arrays or view-side transformations.
  </p>

  <div class="preview-callout">
    <p class="preview-callout__eyebrow">What usually goes wrong</p>
    <ul class="preview-callout__list">
      {% for painPoint in painPoints %}
        <li>{{ painPoint }}</li>
      {% endfor %}
    </ul>
  </div>

  <div class="preview-stats">
    {% for signal in signals %}
      <div class="preview-stats__item">
        <span class="preview-stats__value">{{ signal.value }}</span>
        <span class="preview-stats__label">{{ signal.label }}</span>
      </div>
    {% endfor %}
  </div>

  <div class="preview-compare">
    {% for item in compare %}
      <article class="preview-compare__card preview-compare__card--{{ item.variant }}">
        <div class="preview-compare__meta">
          <p class="preview-compare__eyebrow">{{ item.eyebrow }}</p>
          <h4 class="preview-compare__title">{{ item.title }}</h4>
        </div>
        <p class="preview-compare__summary">{{ item.summary }}</p>
        <p class="preview-note">{{ item.note }}</p>
      </article>
    {% endfor %}
  </div>

  <div class="preview-table">
    <table>
      <thead>
        <tr>
          <th>Presentation field</th>
          <th>Why it exists</th>
          <th>Owned by</th>
        </tr>
      </thead>
      <tbody>
        {% for column in columns %}
          <tr>
            <td><code>{{ column.name }}</code></td>
            <td>{{ column.note }}</td>
            <td><span class="preview-pill">{{ column.owner }}</span></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<div class="preview-card">
  <p class="preview-card__eyebrow">SSR-First Live UI</p>
  <h3 class="preview-card__title">{{ title }}</h3>
  <p class="preview-card__summary">{{ summary }}</p>

  <div class="preview-checklist">
    {% for rule in rules %}
      <div class="preview-checklist__item">
        <span class="preview-checklist__icon" aria-hidden="true">+</span>
        <p>{{ rule }}</p>
      </div>
    {% endfor %}
  </div>

  <div class="preview-table">
    <table>
      <thead>
        <tr>
          <th>Capability</th>
          <th>What Semitexa makes explicit</th>
        </tr>
      </thead>
      <tbody>
        {% for check in checks %}
          <tr>
            <td><span class="preview-pill">{{ check.label }}</span></td>
            <td>{{ check.detail }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<div class="preview-card">
  {% if eyebrow is defined and eyebrow %}
    <p class="preview-card__eyebrow">{{ eyebrow }}</p>
  {% endif %}
  {% if title is defined and title %}
    <h3 class="preview-card__title">{{ title }}</h3>
  {% endif %}
  {% if summary is defined and summary %}
    <p class="preview-card__summary">{{ summary }}</p>
  {% endif %}

  {% if paragraphs is defined and paragraphs|length > 0 %}
    <div class="preview-copy">
      {% for paragraph in paragraphs %}
        <p>{{ paragraph }}</p>
      {% endfor %}
    </div>
  {% endif %}

  {% if form is defined and form %}
    <form method="{{ form.method|default('POST') }}" action="{{ form.action|default('') }}" class="preview-form">
      {% for hidden in form.hidden|default([]) %}
        <input type="hidden" name="{{ hidden.name }}" value="{{ hidden.value }}">
      {% endfor %}
      <button type="submit" class="preview-button preview-button--{{ form.variant|default('primary') }}">{{ form.label }}</button>
    </form>
  {% endif %}

  {% if codeSnippet is defined and codeSnippet %}
    <pre class="preview-code"><code>{{ codeSnippet }}</code></pre>
  {% endif %}

  {% if columns is defined and columns|length > 0 %}
    <div class="preview-table-wrap">
      <table class="preview-table">
        <thead>
          <tr>
            {% for column in columns %}
              <th>{{ column }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% if rows|default([])|length > 0 %}
            {% for row in rows %}
              <tr>
                {% for cell in row %}
                  <td>
                    {% if cell.variant is defined and cell.variant %}
                      <span class="preview-pill preview-pill--{{ cell.variant }}">{{ cell.text }}</span>
                    {% elseif cell.code is defined and cell.code %}
                      <code>{{ cell.text }}</code>
                    {% else %}
                      {{ cell.text }}
                    {% endif %}
                  </td>
                {% endfor %}
              </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="{{ columns|length }}">{{ emptyMessage|default('No rows available.') }}</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>
  {% endif %}

  {% if note is defined and note %}
    <p class="preview-note">{{ note }}</p>
  {% endif %}
</div>

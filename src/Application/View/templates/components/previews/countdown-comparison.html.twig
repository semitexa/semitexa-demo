{{ asset_require('semitexa-demo:js:deferred/countdown-timer') }}

<div class="preview-card">
  {% if eyebrow is defined and eyebrow %}
    <p class="preview-card__eyebrow">{{ eyebrow }}</p>
  {% endif %}
  {% if title is defined and title %}
    <h3 class="preview-card__title">{{ title }}</h3>
  {% endif %}
  {% if summary is defined and summary %}
    <p class="preview-card__summary">{{ summary }}</p>
  {% endif %}

  <div class="preview-grid preview-grid--two-up">
    {% for timer in timers|default([]) %}
      {% include '@project-layouts-semitexa-demo/deferred/countdown-timer.html.twig' with {
        label: timer.label,
        duration: timer.duration,
        instanceId: timer.instanceId,
        badgeText: 'Isolated runtime',
        summaryText: 'This widget runs its own timer state and restart flow without touching the other instance.',
      } only %}
    {% endfor %}
  </div>
</div>

<div class="preview-card">
  <p class="preview-card__eyebrow">Session State</p>
  <h3 class="preview-card__title">{{ stateTitle }}</h3>
  <p class="preview-card__summary">{{ stateSummary }}</p>

  {% if isAuthenticated %}
    <div class="preview-card__notice preview-card__notice--auth">
      <span class="preview-pill preview-pill--active">{{ authSignedInLabel|default('Signed in with Google') }}</span>
      <p class="preview-card__summary">
        {{ displayName|default(email|default('Google user')) }}
        {% if email is defined and email %}
          <span style="display:block; opacity:.8;">{{ email }}</span>
        {% endif %}
      </p>
      <div class="preview-actions">
        <a class="preview-button preview-button--secondary" href="{{ googleLogoutUrl }}">Sign out</a>
      </div>
    </div>
  {% else %}
    {% include '@project-layouts-semitexa-demo/components/previews/google-auth-cta.html.twig' with {
      href: startUrl|default(authPageUrl),
      message: authRequiredMessage|default('Sign in with Google to unlock the role selector and permissions demo.'),
      actionLabel: authActionLabel|default('Sign in with Google'),
      pillLabel: authActionLabel|default('Google sign-in') ~ ' required'
    } only %}
  {% endif %}

  {% if isAuthenticated %}
    <div class="preview-stats">
      <div class="preview-stats__item">
        <span class="preview-stats__value">{{ currentRole }}</span>
        <span class="preview-stats__label">Role</span>
      </div>
      <div class="preview-stats__item">
        <span class="preview-stats__value">{{ permissions|length }}</span>
        <span class="preview-stats__label">Permissions</span>
      </div>
      <div class="preview-stats__item">
        <span class="preview-stats__value">{{ emailVerified ? 'Yes' : 'No' }}</span>
        <span class="preview-stats__label">Verified email</span>
      </div>
    </div>

    {% if permissions is defined and permissions|length > 0 %}
      <div class="preview-card__chips">
        {% for permission in permissions %}
          <span class="preview-chip">{{ permission }}</span>
        {% endfor %}
      </div>
    {% endif %}

    <form method="POST" action="{{ roleChangeUrl }}" class="preview-form preview-form--stacked">
      <input type="hidden" name="action" value="set_role" />
      <div class="preview-actions">
        {% for role in roles %}
          <button type="submit" name="role" value="{{ role.key }}" class="preview-button {{ role.key == currentRole ? 'preview-button--primary' : 'preview-button--secondary' }}">
            {{ role.key == currentRole ? 'Current: ' : 'Switch to ' }}{{ role.label }}
          </button>
        {% endfor %}
      </div>
    </form>
  {% endif %}

</div>

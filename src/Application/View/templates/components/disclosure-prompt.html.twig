{% set normalizedLabel = label ends with '→' ? label|slice(0, -1)|trim : label %}
<button
  type="button"
  class="disclosure-prompt disclosure-prompt--{{ variant }}"
  aria-controls="{{ target }}"
  aria-expanded="false"
  data-disclosure-trigger="{{ target }}"
>
  <span class="disclosure-prompt__label">{{ normalizedLabel }}</span>
  <span class="disclosure-prompt__arrow" aria-hidden="true">→</span>
</button>

<!doctype html>
<html lang="{{ locale|default('en') }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% block title %}{{ title|default('Semitexa Demo') }}{% endblock %}</title>
    {{ meta('description') }}
    {{ meta('keywords') }}
    {{ meta('og:title') }}
    {{ meta('og:description') }}
    {{ meta('og:type') }}
    {{ semantic_head() }}
    {{ asset_head() }}
    {{ __ssr_preload_hints|default('')|raw }}
    {% block head_extra %}{{ layout_slot('head_extra') }}{% endblock %}
  </head>
  <body class="demo-layout" {{ __ssr_handle_attr|default('')|raw }}>

    {# --- Top navigation bar --- #}
    <header class="demo-header">
      {% block header %}
        {% include '@project-layouts-semitexa-demo/partials/nav.html.twig' with {
          sections: navSections|default(featureTree|default(sections|default([]))),
          currentSection: currentSection|default(null),
        } only %}
      {% endblock %}
    </header>

    {# --- Three-zone layout: sidebar + main + info panel --- #}
    <div class="demo-layout__grid">

      {# Sidebar: feature tree navigation (240px) #}
      <aside class="demo-layout__sidebar" aria-label="Feature navigation">
        {% block sidebar %}
          {% include '@project-layouts-semitexa-demo/partials/sidebar.html.twig' with {
            featureTree: featureTree|default(navSections|default(sections|default([]))),
            currentSection: currentSection|default(null),
            currentSlug: currentSlug|default(null),
          } only %}
        {% endblock %}
      </aside>

      {# Main content area (fluid) #}
      <main class="demo-layout__main">
        {% block main %}
          {{ layout_slot('main_before') }}
          {{ main|default(content|default(''))|raw }}
          {{ layout_slot('main_after') }}
        {% endblock %}
      </main>

      {# Info panel: What / How / Why (280px) #}
      <aside class="demo-layout__info" aria-label="Feature information">
        {% block info_panel %}
          {% include '@project-layouts-semitexa-demo/partials/feature-info.html.twig' with {
            what: infoWhat|default(summary|default(sectionSummary|default(null))),
            how: infoHow|default(null),
            why: infoWhy|default(null),
            keywords: infoKeywords|default([]),
          } only %}
        {% endblock %}
      </aside>

    </div>

    <footer class="demo-footer">
      {% block footer %}
        <p>Semitexa Framework Demo &middot; Built with <a href="https://semitexa.com">Semitexa</a></p>
      {% endblock %}
    </footer>

    {{ __ssr_deferred_manifest|default('')|raw }}
    {{ __ssr_runtime_script|default('')|raw }}
    {{ asset_body() }}
  </body>
</html>

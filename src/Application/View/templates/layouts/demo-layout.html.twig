<!doctype html>
<html lang="{{ locale|default('en') }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>{% block title %}{{ page_title()|default('Semitexa Demo') }}{% endblock %}</title>
    <link rel="canonical" href="{{ current_absolute_url() }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    {{ meta('description') }}
    {{ meta('robots') }}
    {{ meta('keywords') }}
    {{ meta('og:title') }}
    {{ meta('og:description') }}
    {{ meta('og:type') }}
    <script>
      (function () {
        try {
          var theme = window.localStorage.getItem('semitexa_demo_theme');
          if (theme !== 'light' && theme !== 'dark') {
            theme = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-demo-theme', theme);
        } catch (error) {
          document.documentElement.setAttribute('data-demo-theme', 'light');
        }
      })();
    </script>
    {{ headExtraMarkup|default('')|raw }}
    {{ semantic_head() }}
    {{ asset_head() }}
    {{ __ssr_preload_hints|default('')|raw }}
    {{ inject_scripts('head') }}
    {% block head_extra %}{{ layout_slot('head_extra') }}{% endblock %}
  </head>
  <body class="demo-layout" {{ __ssr_handle_attr|default('')|raw }}>

    {# --- Top navigation bar --- #}
    <header class="demo-header">
      {% block header %}
        {% include '@project-layouts-semitexa-demo/partials/nav.html.twig' with {
          sections: navSections|default(featureTree|default(sections|default([]))),
          currentSection: currentSection|default(null),
          navMode: navMode|default(null),
          authUi: authUi|default({}),
        } only %}
      {% endblock %}
    </header>

    <div class="demo-layout__sidebar-overlay" hidden data-demo-nav-overlay></div>

    {# --- Two-zone layout: sidebar + main document --- #}
    <div class="demo-layout__grid">

      {# Sidebar: feature tree navigation (240px) #}
      <aside id="demo-sidebar" class="demo-layout__sidebar" aria-label="Feature navigation" data-demo-sidebar>
        <div class="demo-layout__sidebar-mobile-bar">
          <p class="demo-layout__sidebar-mobile-title">Browse Demo Features</p>
          <button
            class="demo-layout__sidebar-close"
            type="button"
            aria-label="Close demo navigation"
            data-demo-nav-close
          >&times;</button>
        </div>
        <div class="demo-layout__sidebar-scroll" data-demo-sidebar-scroll>
          {% block sidebar %}
            {% include '@project-layouts-semitexa-demo/partials/sidebar.html.twig' with {
              featureTree: featureTree|default(navSections|default(sections|default([]))),
              currentSection: currentSection|default(null),
              currentSlug: currentSlug|default(null),
              navMode: navMode|default(null),
              activeLayerKey: activeLayerKey|default(null),
            } only %}
          {% endblock %}
        </div>
      </aside>

      {# Main content area (fluid) #}
      <main class="demo-layout__main">
        {% block main %}
          {{ layout_slot('main_before') }}
          {{ main|default(content|default(''))|raw }}
          {{ layout_slot('main_after') }}
        {% endblock %}
      </main>

    </div>

    <footer class="demo-footer">
      {% block footer %}
        <p>© 2026 Semitexa</p>
      {% endblock %}
    </footer>

    {{ __ssr_deferred_manifest|default('')|raw }}
    {{ __ssr_runtime_script|default('')|raw }}
    {{ asset_body() }}
    {{ inject_scripts('body') }}
  </body>
</html>

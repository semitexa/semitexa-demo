<!doctype html>
<html lang="{{ locale|default('en') }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ page_title()|default('Deferred Blocks — Semitexa Demo') }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    {{ asset_require('semitexa-demo:js:deferred-timeline') }}
    {{ meta('description') }}
    {{ meta('keywords') }}
    {{ meta('og:title') }}
    {{ meta('og:description') }}
    {{ meta('og:type') }}
    <script>
      (function () {
        try {
          var theme = window.localStorage.getItem('semitexa_demo_theme');
          if (theme !== 'light' && theme !== 'dark') {
            theme = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-demo-theme', theme);
          window.__resolvedDemoTheme = theme;
        } catch (error) {
          document.documentElement.setAttribute('data-demo-theme', 'light');
          window.__resolvedDemoTheme = 'light';
        }
      })();
    </script>
    {{ semantic_head() }}
    {{ asset_head() }}
    {{ __ssr_preload_hints|default('')|raw }}
  </head>
  <body class="demo-layout deferred-demo-page" {{ __ssr_handle_attr|default('')|raw }}>
    {% set headerAuth = resultPreviewData|default({}) %}
    {% set headerAuthIsAuthenticated = headerAuth.isAuthenticated|default(false) %}
    {% set headerAuthHref = headerAuthIsAuthenticated
      ? headerAuth.authPageUrl|default('/demo/auth/google?return_to=%2Fdemo%2Frendering%2Fdeferred')
      : headerAuth.startUrl|default('/demo/auth/google/start?return_to=%2Fdemo%2Frendering%2Fdeferred') %}
    {% set headerAuthTitle = headerAuthIsAuthenticated
      ? (headerAuth.email|default(headerAuth.displayName|default('Signed in with Google')))
      : headerAuth.authSignInTitle|default('Sign in with Google to unlock advanced demos') %}
    {% set headerAuthText = headerAuthIsAuthenticated
      ? 'Hi, ' ~ (headerAuth.displayName|default('there')|split(' ')|first)
      : headerAuth.authActionLabel|default('Sign in') %}
    <script>
      (function () {
        var theme = window.__resolvedDemoTheme || document.documentElement.getAttribute('data-demo-theme') || 'light';
        var label = theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode';
        var text = theme === 'dark' ? 'Light mode' : 'Dark mode';
        var toggle = document.querySelector('[data-demo-theme-toggle]');
        var textNode = document.querySelector('[data-demo-theme-text]');
        if (toggle) {
          toggle.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
          toggle.setAttribute('aria-label', label);
          toggle.setAttribute('title', 'Toggle color theme');
        }
        if (textNode) {
          textNode.textContent = text;
        }
      })();
    </script>
    <header class="demo-header">
      <nav class="demo-nav" aria-label="Demo navigation">
        <a class="demo-nav__brand" href="/">
          <span class="demo-nav__title">
            <span class="semitexa-logo" aria-label="Semitexa">Semite<span>xa</span></span>
          </span>
        </a>
        <ul class="demo-nav__sections">
          <li class="demo-nav__item demo-nav__item--active"><a href="/demo/rendering">Rendering &amp; SSR</a></li>
        </ul>
        <div class="demo-nav__actions">
          <a class="demo-nav__signin{{ headerAuthIsAuthenticated ? ' demo-nav__signin--active' : '' }}" href="{{ headerAuthHref }}" title="{{ headerAuthTitle }}">
            <span class="demo-nav__signin-dot" aria-hidden="true"></span>
            <span class="demo-nav__signin-text">{{ headerAuthText }}</span>
          </a>
          <div class="demo-nav__theme-control">
            <span class="demo-nav__theme-text" aria-hidden="true" data-demo-theme-text>Dark mode</span>
            <button
              class="demo-nav__theme-toggle"
              type="button"
              aria-pressed="false"
              aria-label="Switch to dark mode"
              title="Toggle color theme"
              data-demo-theme-toggle
            >
              <span class="demo-nav__theme-toggle-track" aria-hidden="true">
                <span class="demo-nav__theme-toggle-thumb"></span>
              </span>
            </button>
          </div>
          <a class="demo-nav__link" href="/demo/rendering">Back to Rendering</a>
        </div>
      </nav>
    </header>

    <main class="demo-layout__main deferred-demo-page__main">
      <article class="feature-detail" data-section="{{ section }}" data-slug="{{ slug }}">
        <section class="feature-detail__l1 deferred-demo-page__hero">
          <header class="feature-detail__header">
            <div class="feature-detail__header-copy">
              <a href="/demo/rendering" class="feature-detail__back">← Rendering</a>
              <p class="feature-detail__eyebrow">SSR-FIRST LIVE UI</p>
              <h1 class="feature-detail__title">{{ demo_title_icon(featureTitle, section, slug) }}{{ featureTitle }}</h1>
              <p class="feature-detail__entry-line">{{ entryLine }}</p>
            </div>
          </header>

          {% if highlights is defined and highlights|length > 0 %}
            <div class="feature-detail__highlights">
              {% for highlight in highlights %}
                <span class="feature-detail__highlight">{{ highlight }}</span>
              {% endfor %}
            </div>
          {% endif %}
        </section>

        <section class="feature-detail__deferred-demo">
          <div class="deferred-demo-page__section-head">
            <div>
              <p class="preview-card__eyebrow">Live deferred surface</p>
              <h2 class="preview-card__title">The shell is already there. These six regions arrive after it.</h2>
            </div>
            <p class="preview-card__summary">Each card below starts as skeleton HTML, appears with a deliberate staggered delay so the arrival sequence is visible, and is later resolved by the deferred runtime. Some stop there to demonstrate one-shot deferred delivery, while others keep reacting to real backend heartbeats over the shared kiss stream.</p>
          </div>

          <div class="deferred-demo-page__live-grid" data-timeline data-total-blocks="6">
            <div class="preview-card deferred-demo-page__timeline-card">
              <p class="preview-card__eyebrow">Arrival meter</p>
              <h3 class="preview-card__title">Watch the deferred slots land in sequence.</h3>
              <p class="preview-card__summary">Each <code>layout_slot_deferred()</code> region dispatches <code>semitexa:block:rendered</code> when its final content lands, whether that happened through direct HTML streaming, client template rendering, or emergency fallback recovery.</p>
              <div class="deferred-timeline">
                <div class="deferred-timeline__track" aria-hidden="true">
                  <div class="deferred-timeline__fill" style="width:0%"></div>
                </div>
                <p class="deferred-timeline__label" role="status" aria-live="polite" aria-atomic="true">0 / 6 blocks loaded</p>
              </div>
            </div>

            <div class="deferred-blocks-grid">
              {{ layout_slot_deferred('deferred_product_carousel') }}
              {{ layout_slot_deferred('deferred_chart_widget') }}
              {{ layout_slot_deferred('deferred_search_filter') }}
              {{ layout_slot_deferred('deferred_countdown') }}
              {{ layout_slot_deferred('deferred_review_feed') }}
              {{ layout_slot_deferred('deferred_notification') }}
            </div>
          </div>
        </section>

        <section class="feature-detail__l1 deferred-demo-page__hero">

          <div class="preview-card deferred-demo-page__primer">
            <div class="preview-card__header">
              <p class="preview-card__eyebrow">Why it matters</p>
              <h2 class="preview-card__title">{{ infoWhat|default('Deferred slots keep SSR pages usable while slower regions stream in later.') }}</h2>
            </div>
            <p class="preview-card__summary">{{ infoHow|default('The shell is rendered first, then the server streams final slot HTML over SSE instead of shipping a client-side rebuild. After arrival, selected widgets can keep reacting to live backend events over the same kiss stream.') }}</p>
            <p class="preview-card__summary">{{ infoWhy|default('You keep one rendering model: HTML in, HTML out, no SPA handoff.') }}</p>
          </div>

          <div class="deferred-demo-page__stats" aria-label="Deferred delivery signals">
            <article class="preview-card preview-card--nested deferred-demo-page__stat">
              <p class="preview-card__eyebrow">First paint</p>
              <h3 class="preview-card__title">Shell is ready before slow regions</h3>
              <p class="preview-card__summary">Navigation, copy, and layout arrive immediately. Expensive regions can take their time.</p>
            </article>
            <article class="preview-card preview-card--nested deferred-demo-page__stat">
              <p class="preview-card__eyebrow">Delivery</p>
              <h3 class="preview-card__title">HTML streams in, not client state</h3>
              <p class="preview-card__summary">The server renders each slot and swaps it into place. No JSON hydration dance and no page rebuild.</p>
            </article>
            <article class="preview-card preview-card--nested deferred-demo-page__stat">
              <p class="preview-card__eyebrow">Architecture</p>
              <h3 class="preview-card__title">One rendering model everywhere</h3>
              <p class="preview-card__summary">Static shell, deferred zones, and live widgets all stay inside the same SSR-first mental model.</p>
            </article>
          </div>

          <div class="deferred-demo-page__section-head">
            <div>
              <p class="preview-card__eyebrow">Delivery modes</p>
              <h2 class="preview-card__title">This page demonstrates the primary deferred delivery paths and documents the emergency fallback separately.</h2>
            </div>
            <p class="preview-card__summary">On this surface you can inspect the two expected steady-state paths: a normal <code>html</code> block streamed as ready markup and a real <code>template</code> block rendered in the browser from a published Twig asset. The <code>fallback</code> path still exists, but it should activate only when SSE delivery or client template rendering actually fails.</p>
          </div>

          <div class="deferred-demo-page__modes" aria-label="Deferred block delivery modes">
            <article class="preview-card preview-card--nested deferred-demo-page__mode deferred-demo-page__mode--recommended">
              <p class="preview-card__eyebrow">Live on this page</p>
              <h3 class="preview-card__title"><code>mode: html</code></h3>
              <p class="preview-card__summary">The server renders the final fragment and streams ready-to-swap HTML over SSE.</p>
              <ul class="deferred-demo-page__mode-list">
                <li>Best for SSR-first pages where the server owns rendering end to end.</li>
                <li>Zero client templating logic after the block arrives.</li>
                <li>Best fit for slots with rich Twig markup, SEO-sensitive content, or server-only presentation rules.</li>
              </ul>
            </article>

            <article class="preview-card preview-card--nested deferred-demo-page__mode">
              <p class="preview-card__eyebrow">Live on this page</p>
              <h3 class="preview-card__title"><code>mode: template</code></h3>
              <p class="preview-card__summary">The server sends structured data plus a published template path, and the browser renders that Twig template locally after the SSE payload arrives.</p>
              <ul class="deferred-demo-page__mode-list">
                <li>Useful when the same template is intentionally shared between server output and deferred client rendering.</li>
                <li>Reduces payload size when HTML would be much heavier than the data slice.</li>
                <li>Use only when the client-side template contract is deliberate and stable.</li>
              </ul>
            </article>

            <article class="preview-card preview-card--nested deferred-demo-page__mode">
              <p class="preview-card__eyebrow">Emergency path</p>
              <h3 class="preview-card__title"><code>mode: fallback</code></h3>
              <p class="preview-card__summary">This is not a slot mode you configure. It is the client runtime's rescue path when SSE delivery or template rendering fails.</p>
              <ul class="deferred-demo-page__mode-list">
                <li>The browser fetches already-rendered slot HTML from the fallback endpoint.</li>
                <li>Useful for resilience, not as the main architecture choice.</li>
                <li>If you see this often, fix the primary deferred path instead of designing around fallback.</li>
              </ul>
            </article>
          </div>
        </section>

        <section class="feature-detail__deferred-demo">
          <div class="deferred-demo-page__flow" aria-label="Deferred rendering flow">
            <div class="deferred-demo-page__flow-step">
              <span class="deferred-demo-page__flow-index">01</span>
              <div>
                <h3>Render shell</h3>
                <p>The page becomes usable immediately with real structure, headings, and navigation.</p>
              </div>
            </div>
            <div class="deferred-demo-page__flow-step">
              <span class="deferred-demo-page__flow-index">02</span>
              <div>
                <h3>Stream late regions</h3>
                <p>Deferred slots keep loading in the background while the user is already on the page.</p>
              </div>
            </div>
            <div class="deferred-demo-page__flow-step">
              <span class="deferred-demo-page__flow-index">03</span>
              <div>
                <h3>Swap HTML in place</h3>
                <p>The browser receives final HTML fragments instead of client-side instructions to rebuild the interface.</p>
              </div>
            </div>
          </div>
          <div class="deferred-demo-page__stream-card">
            {% include '@project-layouts-semitexa-demo/components/previews/sse-stream.html.twig' with resultPreviewData|default({}) only %}
          </div>
        </section>
      </article>
    </main>

    <footer class="demo-footer">
      <p>© 2026 Semitexa</p>
    </footer>

    {{ __ssr_deferred_manifest|default('')|raw }}
    {{ __ssr_runtime_script|default('')|raw }}
    {{ asset_body() }}
  </body>
</html>

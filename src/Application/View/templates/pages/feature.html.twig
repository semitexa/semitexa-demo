{% extends '@project-layouts-semitexa-demo/layouts/demo-layout.html.twig' %}

{% block title %}{{ featureTitle|default('Feature') }} — Semitexa Demo{% endblock %}

{% block main %}
  {% set domKey = (section ~ '-' ~ slug)|lower|replace({' ': '-', '/': '-', '\\': '-', '_': '-'}) %}
  {% set resolvedSectionLabel = sectionLabel|default(section|title) %}
  {% set keywordDefinitions = {} %}
  {% if explanation is defined and explanation.keywords is defined %}
    {% for keyword in explanation.keywords %}
      {% set keywordDefinitions = keywordDefinitions|merge({ (keyword.term): keyword.definition }) %}
    {% endfor %}
  {% endif %}
  <article class="feature-detail" data-section="{{ section }}" data-slug="{{ slug }}">

    <section class="feature-detail__l1">
      <header class="feature-detail__header">
        <div class="feature-detail__header-copy">
          <a href="/demo/{{ section }}" class="feature-detail__back">← {{ resolvedSectionLabel }}</a>
          <p class="feature-detail__eyebrow">{{ resolvedSectionLabel|upper }} FEATURE</p>
          <h1 class="feature-detail__title">
            {{ demo_title_icon(featureTitle, section, slug) }}
            <span>{{ featureTitle }}</span>
          </h1>
          <p class="feature-detail__entry-line">{{ entryLine }}</p>
        </div>

        {% if highlights is defined and highlights|length > 0 %}
          <div class="feature-detail__summary-card">
            <p class="feature-detail__summary-label">Working surface</p>
            <p class="feature-detail__summary-text">This page shows live behavior first, then source and deeper internals one layer below.</p>
          </div>
        {% endif %}
      </header>

      {% if resultPreviewTemplate is defined and resultPreviewTemplate %}
        <div class="feature-detail__preview" aria-label="Result preview">
          {% include resultPreviewTemplate with resultPreviewData|default({}) only %}
        </div>
      {% elseif resultPreview is defined and resultPreview %}
        <div class="feature-detail__preview" aria-label="Result preview">
          {{ resultPreview|raw }}
        </div>
      {% endif %}

      {% if highlights is defined and highlights|length > 0 %}
        <div class="feature-detail__highlights">
          {% for highlight in highlights %}
            {% set definition = attribute(keywordDefinitions, highlight)|default(null) %}
            {% if definition %}
              <span class="feature-detail__highlight feature-detail__highlight--interactive">
                {% include '@project-layouts-semitexa-demo/components/explanation-tooltip.html.twig' with {
                  term: highlight,
                  definition: definition,
                } only %}
              </span>
            {% else %}
              <span class="feature-detail__highlight feature-detail__highlight--plain">{{ highlight }}</span>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {% set inlineWhat = infoWhat|default(summary|default(sectionSummary|default(null))) %}
      {% set inlineHow = infoHow|default(explanation.how|default(null)) %}
      {% set inlineWhy = infoWhy|default(explanation.why|default(null)) %}
      {% set inlineKeywords = infoKeywords|default(explanation.keywords|default([])) %}
      {% if inlineWhat or inlineHow or inlineWhy or inlineKeywords|length > 0 %}
        <div class="feature-detail__context">
          {% include '@project-layouts-semitexa-demo/partials/feature-info.html.twig' with {
            what: inlineWhat,
            how: inlineHow,
            why: inlineWhy,
            keywords: inlineKeywords,
          } only %}
        </div>
      {% endif %}
    </section>

    {% if (sourceCode is defined and sourceCode|length > 0) or (l2ContentTemplate is defined and l2ContentTemplate) or (l2Content is defined and l2Content) or (relatedPayloads is defined and relatedPayloads|length > 0) %}
      <section class="feature-detail__l2">
        {% if sourceCode is defined and sourceCode|length > 0 %}
          {{ component('demo-code-block', {
            tabs: sourceCode,
            featureSlug: slug,
          }) }}
        {% endif %}

        {% if l2ContentTemplate is defined and l2ContentTemplate %}
          <div class="feature-detail__l2-extra">
            {% include l2ContentTemplate with l2ContentData|default({}) only %}
          </div>
        {% elseif l2Content is defined and l2Content %}
          <div class="feature-detail__l2-extra">
            {{ l2Content|raw }}
          </div>
        {% endif %}

        {% if relatedPayloads is defined and relatedPayloads|length > 0 %}
          <div class="feature-detail__related">
            <h3 class="feature-detail__related-heading">Related features</h3>
            <ul class="feature-detail__related-list">
              {% for related in relatedPayloads %}
                <li><a href="/demo/{{ related|url_encode }}">{{ related }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {{ component('demo-disclosure-prompt', {
          label: deepDiveLabel|default('Under the hood →'),
          variant: 'deepDive',
          target: 'l3-' ~ domKey,
        }) }}
      </section>
    {% endif %}

    <div id="l3-{{ domKey }}" class="deep-dive-drawer" data-expanded="false" data-drawer>
      <div class="deep-dive-drawer__overlay" data-drawer-close></div>
      <div class="deep-dive-drawer__panel">
        <button class="deep-dive-drawer__close" type="button" aria-label="Close details panel" data-drawer-close>&times;</button>
        <div class="deep-dive-drawer__content">
          <div class="feature-detail__l3">
            {% if explanation is defined %}
              {% if explanation.how is defined and explanation.how %}
                <section class="feature-detail__l3-section">
                  <h3>How it works</h3>
                  <p>{{ explanation.how }}</p>
                </section>
              {% endif %}
              {% if explanation.why is defined and explanation.why %}
                <section class="feature-detail__l3-section">
                  <h3>Why it matters</h3>
                  <p>{{ explanation.why }}</p>
                </section>
              {% endif %}
              {% if explanation.keywords is defined and explanation.keywords|length > 0 %}
                <section class="feature-detail__l3-section">
                  <h3>Key concepts</h3>
                  <dl class="feature-detail__keywords">
                    {% for kw in explanation.keywords %}
                      <dt>{{ kw.term }}</dt>
                      <dd>{{ kw.definition }}</dd>
                    {% endfor %}
                  </dl>
                </section>
              {% endif %}
            {% endif %}

            {% if l3ContentTemplate is defined and l3ContentTemplate %}
              <div class="feature-detail__l3-extra">
                {% include l3ContentTemplate with l3ContentData|default({}) only %}
              </div>
            {% elseif l3Content is defined and l3Content %}
              <div class="feature-detail__l3-extra">
                {{ l3Content|raw }}
              </div>
            {% endif %}

          </div>
        </div>
      </div>
    </div>

  </article>
{% endblock %}

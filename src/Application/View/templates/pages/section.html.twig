{% extends '@project-layouts-semitexa-demo/layouts/demo-layout.html.twig' %}

{% block title %}{{ page_title()|default((sectionLabel|default('Section')) ~ ' — Semitexa Demo') }}{% endblock %}

{% block main %}
  <div class="demo-section-page">

    <header class="demo-section-page__header">
      <a href="/" class="demo-section-page__back">← All sections</a>
      <div class="demo-section-page__masthead">
        <div class="demo-section-page__title-row">
          <span class="demo-section-page__icon" aria-hidden="true">{{ sectionIcon|default('') }}</span>
          <div>
            <p class="demo-section-page__eyebrow">Section Overview</p>
            <h1 class="demo-section-page__title">{{ sectionLabel|default('') }}</h1>
          </div>
        </div>
        <div class="demo-section-page__stat">
          <span class="demo-section-page__stat-value">{{ features|default([])|length }}</span>
          <span class="demo-section-page__stat-label">live features</span>
        </div>
      </div>
      <p class="demo-section-page__summary">{{ sectionSummary|default('') }}</p>
      {% include '@project-layouts-semitexa-demo/partials/donate-block.html.twig' only %}
    </header>

    {% if section|default('') == 'rendering' %}
      <section class="demo-section-page__manifesto">
        <div class="preview-card preview-card--layered rendering-manifesto">
          <div class="rendering-manifesto__intro">
            <p class="demo-block-heading__eyebrow">Core Idea</p>
            <h2 class="preview-card__title">One rendering story, not two</h2>
            <p class="preview-card__summary">Semitexa treats server rendering, page regions, and live updates as one coherent system. The goal is to stop splitting template logic into a backend version for first paint and a different frontend version for everything interactive.</p>
          </div>
          <div class="preview-stats">
            <article class="preview-stats__item">
              <strong class="preview-stats__value">1</strong>
              <span class="preview-stats__label">template language from first render to live update</span>
            </article>
            <article class="preview-stats__item">
              <strong class="preview-stats__value">0</strong>
              <span class="preview-stats__label">forced SPA handoffs just to keep the UI reactive</span>
            </article>
            <article class="preview-stats__item">
              <strong class="preview-stats__value">KISS</strong>
              <span class="preview-stats__label">keep the page honest: server truth in, HTML out</span>
            </article>
          </div>
          <div class="preview-checklist rendering-manifesto__points">
            <article class="preview-checklist__item">
              <span class="preview-checklist__mark" aria-hidden="true">1</span>
              <p>Handlers shape explicit response data once, so templates stop reverse-engineering random arrays and view state.</p>
            </article>
            <article class="preview-checklist__item">
              <span class="preview-checklist__mark" aria-hidden="true">2</span>
              <p>Slots and deferred regions reuse the same rendering model as the page shell, so “dynamic UI” does not become a separate frontend architecture.</p>
            </article>
            <article class="preview-checklist__item">
              <span class="preview-checklist__mark" aria-hidden="true">3</span>
              <p>When the data changes, the server re-renders the truth as HTML. The interface stays simple because the rendering philosophy stays simple.</p>
            </article>
          </div>
        </div>
      </section>
    {% endif %}

    {% if section|default('') == 'get-started' %}
      <section class="demo-section-page__manifesto">
        <div class="preview-card preview-card--layered demo-get-started-structure">
          <div class="rendering-manifesto__intro">
            <p class="demo-block-heading__eyebrow">Module Structure</p>
            <h2 class="preview-card__title">The module has a minimal HTTP spine and an extended product stack</h2>
            <p class="preview-card__summary">Use the minimal version to understand the request path itself. Use the extended version to understand how Semitexa turns that path into a guided demo module with SEO, navigation, and source-backed context.</p>
          </div>

          <div class="demo-get-started-structure__grid">
            <article class="preview-card preview-card--nested demo-get-started-structure__card">
              <p class="preview-card__eyebrow">Minimal Stack</p>
              <h3 class="preview-card__title">The smallest useful request flow</h3>
              <p class="preview-card__summary">This is the narrow path that needs to exist for any simple feature page: transport in, use case out, response rendered.</p>
              <div class="preview-checklist demo-get-started-structure__list">
                <div class="preview-checklist__item">
                  <span class="preview-checklist__mark" aria-hidden="true">1</span>
                  <p><strong>Payload</strong> owns the route contract, path params, and request boundary.</p>
                </div>
                <div class="preview-checklist__item">
                  <span class="preview-checklist__mark" aria-hidden="true">2</span>
                  <p><strong>Handler</strong> owns the use case and produces one typed resource.</p>
                </div>
                <div class="preview-checklist__item">
                  <span class="preview-checklist__mark" aria-hidden="true">3</span>
                  <p><strong>Resource</strong> owns the outgoing response, metadata, and render context.</p>
                </div>
                <div class="preview-checklist__item">
                  <span class="preview-checklist__mark" aria-hidden="true">4</span>
                  <p><strong>Template</strong> owns presentation only and stays declarative.</p>
                </div>
              </div>
            </article>

            <article class="preview-card preview-card--nested demo-get-started-structure__card">
              <p class="preview-card__eyebrow">Extended Stack</p>
              <h3 class="preview-card__title">The full module as a guided demo system</h3>
              <p class="preview-card__summary">Once the route works, the demo layers on a catalog, curated navigation, SEO defaults, grouped learning order, and source-linked explanations.</p>
              <div class="preview-checklist demo-get-started-structure__list">
                <div class="preview-checklist__item">
                  <span class="preview-checklist__mark" aria-hidden="true">1</span>
                  <p><strong>Catalog service</strong> assembles sections, groups, and navigation layers.</p>
                </div>
                <div class="preview-checklist__item">
                  <span class="preview-checklist__mark" aria-hidden="true">2</span>
                  <p><strong>Shell context</strong> adds SEO defaults, nav mode, and shared demo metadata.</p>
                </div>
                <div class="preview-checklist__item">
                  <span class="preview-checklist__mark" aria-hidden="true">3</span>
                  <p><strong>Section pages</strong> explain the learning order and group live routes by responsibility.</p>
                </div>
                <div class="preview-checklist__item">
                  <span class="preview-checklist__mark" aria-hidden="true">4</span>
                  <p><strong>Preview templates</strong> make the module feel like a product, not a stack of loose samples.</p>
                </div>
              </div>
            </article>
          </div>

          <div class="demo-get-started-owners">
            <div class="demo-get-started-owners__head">
              <p class="demo-block-heading__eyebrow">Responsibility Map</p>
              <p class="demo-block-heading__text">The demo becomes easier to learn when every layer keeps one job and the module description says that out loud.</p>
            </div>
            <div class="demo-get-started-owners__grid">
              <article class="demo-get-started-owners__item">
                <strong>Payload</strong>
                <span>Route contract, validation boundary, alternates.</span>
              </article>
              <article class="demo-get-started-owners__item">
                <strong>Handler</strong>
                <span>Use case orchestration and feature-level decisions.</span>
              </article>
              <article class="demo-get-started-owners__item">
                <strong>Resource</strong>
                <span>Response shape, SEO defaults, and render context.</span>
              </article>
              <article class="demo-get-started-owners__item">
                <strong>Catalog</strong>
                <span>Sections, groups, feature tree, and navigation layers.</span>
              </article>
              <article class="demo-get-started-owners__item">
                <strong>Layout</strong>
                <span>Shell chrome, canonical URL, and shared metadata.</span>
              </article>
              <article class="demo-get-started-owners__item">
                <strong>Templates</strong>
                <span>Progressive disclosure and story-driven presentation.</span>
              </article>
            </div>
          </div>
        </div>
      </section>
    {% endif %}

    {% if section|default('') == 'project-graph' %}
      <section class="demo-section-page__manifesto">
        <div class="preview-card preview-card--layered">
          <div class="rendering-manifesto__intro">
            <p class="demo-block-heading__eyebrow">Marketing Feature</p>
            <h2 class="preview-card__title">A real codebase map beats grep-driven guesswork</h2>
            <p class="preview-card__summary">`semitexa-project-graph` is not decorative metadata. It builds a live structural graph that makes Semitexa easier to learn, safer to change, and much more usable for AI-assisted work. Instead of forcing engineers or agents to rediscover modules and dependencies from scratch on every task, the framework can answer those questions directly.</p>
          </div>
          <div class="preview-stats">
            <article class="preview-stats__item">
              <strong class="preview-stats__value">1</strong>
              <span class="preview-stats__label">incremental graph refresh before deep edits</span>
            </article>
            <article class="preview-stats__item">
              <strong class="preview-stats__value">Fast</strong>
              <span class="preview-stats__label">dependency lookup, capability discovery, and focused impact checks</span>
            </article>
            <article class="preview-stats__item">
              <strong class="preview-stats__value">Safer</strong>
              <span class="preview-stats__label">AI and humans both start from actual structure instead of assumptions</span>
            </article>
          </div>
          <div class="preview-checklist rendering-manifesto__points">
            <article class="preview-checklist__item">
              <span class="preview-checklist__mark" aria-hidden="true">1</span>
              <p><strong>Generate once, reuse everywhere.</strong> The graph becomes shared project memory for capability manifests, dependency exploration, and change analysis.</p>
            </article>
            <article class="preview-checklist__item">
              <span class="preview-checklist__mark" aria-hidden="true">2</span>
              <p><strong>Explain the system structurally.</strong> Routes, services, handlers, entities, and module boundaries stop being hidden behind naming conventions alone.</p>
            </article>
            <article class="preview-checklist__item">
              <span class="preview-checklist__mark" aria-hidden="true">3</span>
              <p><strong>Feed better AI context.</strong> Instead of pasting half the repository into prompts, teams can package targeted impact context and prompt scaffolds directly from the graph.</p>
            </article>
          </div>
        </div>
      </section>
    {% endif %}

    {% if features|default([])|length > 0 %}
      <section class="demo-section-page__features">
        <div class="demo-block-heading demo-block-heading--tight">
          <p class="demo-block-heading__eyebrow">{{ section|default('') == 'rendering' ? 'Conceptual Path' : (section|default('') == 'get-started' ? 'Onboarding Pages' : (section|default('') == 'project-graph' ? 'Usage Paths' : 'Route Map')) }}</p>
          <p class="demo-block-heading__text">{{ section|default('') == 'rendering' ? 'Read the section as a progression: start with the rendering model, then move through delivery, and only then into the live surfaces that reuse the same server-owned story.' : (section|default('') == 'get-started' ? 'Open these pages in order if you want the shortest path from a fresh install to a realistic Semitexa local setup.' : (section|default('') == 'project-graph' ? 'Start with the overview, then move into inspection and impact workflows to see how the graph helps real engineering and AI-assisted work.' : 'Each feature page pairs live output with the source that produced it.')) }}</p>
        </div>
        {% if groups|default([]) is not empty %}
          <div class="demo-section-page__groups">
            {% for group in groups|default([]) %}
              <section class="demo-section-page__group">
                <div class="demo-section-page__group-head">
                  <h3 class="demo-section-page__group-title">{{ group.label }}</h3>
                  <span class="demo-section-page__group-count">{{ group.featureCount }}</span>
                </div>
                <div class="demo-sections__grid">
                  {% for feature in group.features|default([]) %}
                    <a
                      href="{{ feature.href|default('/demo/' ~ (section|url_encode) ~ '/' ~ (feature.slug|url_encode)) }}"
                      class="feature-card feature-card--feature"
                      {% if feature.opensInNewTab|default(false) %}aria-label="{{ feature.title }} (opens in new tab)"{% endif %}
                      {% if feature.opensInNewTab|default(false) %}target="_blank" rel="noopener"{% endif %}
                    >
                      <div class="feature-card__body">
                        <p class="feature-card__eyebrow">{{ sectionLabel|default(section|upper) }}</p>
                        <h3 class="feature-card__title">{{ feature.title }}{% if feature.opensInNewTab|default(false) %}<span class="demo-link-external-indicator" aria-hidden="true">↗</span>{% endif %}</h3>
                        <p class="feature-card__summary">{{ feature.summary }}</p>
                        <div class="feature-card__meta">
                          <span class="feature-card__count">Open feature</span>
                        </div>
                      </div>
                    </a>
                  {% endfor %}
                </div>
              </section>
            {% endfor %}
          </div>
        {% else %}
          <div class="demo-sections__grid">
            {% for feature in features %}
              <a
                href="{{ feature.href|default('/demo/' ~ (section|url_encode) ~ '/' ~ (feature.slug|url_encode)) }}"
                class="feature-card feature-card--feature"
                {% if feature.opensInNewTab|default(false) %}aria-label="{{ feature.title }} (opens in new tab)"{% endif %}
                {% if feature.opensInNewTab|default(false) %}target="_blank" rel="noopener"{% endif %}
              >
                <div class="feature-card__body">
                  <p class="feature-card__eyebrow">{{ sectionLabel|default(section|upper) }}</p>
                  <h3 class="feature-card__title">{{ feature.title }}{% if feature.opensInNewTab|default(false) %}<span class="demo-link-external-indicator" aria-hidden="true">↗</span>{% endif %}</h3>
                  <p class="feature-card__summary">{{ feature.summary }}</p>
                  <div class="feature-card__meta">
                    <span class="feature-card__count">Open feature</span>
                  </div>
                </div>
              </a>
            {% endfor %}
          </div>
        {% endif %}
      </section>
    {% else %}
      <p class="demo-section-page__empty">No features in this section yet.</p>
    {% endif %}

  </div>
{% endblock %}

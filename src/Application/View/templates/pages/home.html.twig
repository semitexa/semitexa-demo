{% extends '@project-layouts-semitexa-demo/layouts/demo-layout.html.twig' %}

{% block title %}Semitexa Demo — Framework Showcase{% endblock %}

{% set readyFeatures = featuredFeatures|default([]) %}
{% if readyFeatures is empty %}
  {% set readyFeatures = [] %}
  {% for section in sections|default([]) %}
    {% for feature in section.features|default([]) %}
      {% if readyFeatures|length < 3 %}
        {% set readyFeatures = readyFeatures|merge([feature]) %}
      {% endif %}
    {% endfor %}
  {% endfor %}
{% endif %}

{% block main %}
  {# --- Hero Section --- #}
  <section class="demo-hero">
    <div class="demo-hero__content">
      <p class="demo-hero__brand">SEMITEXA FRAMEWORK</p>
      <h1 class="demo-hero__tagline">See the framework behaving like a product, not like a brochure.</h1>
      <p class="demo-hero__lede">Routes, DI, ORM, SSR, tenancy, and async flows presented as one connected system with working entry points.</p>
      <div class="demo-hero__ctas">
        <a href="#sections" class="demo-hero__cta demo-hero__cta--primary">Explore Features</a>
        <a href="https://github.com/semitexa" class="demo-hero__cta demo-hero__cta--secondary" target="_blank" rel="noopener">View Source</a>
        <a href="https://semitexa.com/docs" class="demo-hero__cta demo-hero__cta--secondary" target="_blank" rel="noopener">Get Started</a>
      </div>
      <div class="demo-hero__badges">
        <span class="demo-hero__badge">PHP 8.4 Attributes</span>
        <span class="demo-hero__badge">Swoole-native</span>
        <span class="demo-hero__badge">Zero Config</span>
      </div>
    </div>
  </section>

  {# --- Starter Cards (above fold) --- #}
  <section class="demo-starters">
    <h2 class="demo-starters__heading">Start here</h2>
    <div class="demo-starters__grid">
      {% for section in starterSections|default([]) %}
        {% include '@project-layouts-semitexa-demo/components/feature-card.html.twig' with {
          href: section.href,
          key: section.key,
          label: section.label,
          summary: section.summary,
          icon: section.icon,
          eyebrow: section.eyebrow,
          featureCount: section.featureCount,
          prerequisites: section.prerequisites,
          starter: true,
        } only %}
      {% endfor %}
    </div>
  </section>

  {# --- Full Section Grid (below fold) --- #}
  <section id="sections" class="demo-sections">
    <h2 class="demo-sections__heading">All sections <span class="demo-sections__count">{{ totalFeatureCount|default(0) }} features</span></h2>
    <div class="demo-sections__grid">
      {% for section in sections|default([]) %}
        {% include '@project-layouts-semitexa-demo/components/feature-card.html.twig' with {
          href: section.href,
          key: section.key,
          label: section.label,
          summary: section.summary,
          icon: section.icon,
          eyebrow: section.eyebrow,
          featureCount: section.featureCount,
          prerequisites: section.prerequisites,
          starter: false,
        } only %}
      {% endfor %}
    </div>
  </section>

  {# --- "Ready for more?" prompt (hidden until 3+ features visited) --- #}
  <section class="demo-ready-prompt" data-ready-prompt style="display: none;">
    <h2 class="demo-ready-prompt__heading">Ready for more?</h2>
    <p class="demo-ready-prompt__text">These working walkthroughs are the best current entry points into the richer parts of the demo:</p>
    <div class="demo-ready-prompt__suggestions">
      {% for feature in readyFeatures %}
        <a href="{{ feature.href }}" class="demo-ready-prompt__link">{{ feature.title }}</a>
      {% endfor %}
    </div>
  </section>
{% endblock %}

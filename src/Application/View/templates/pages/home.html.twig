{% extends '@project-layouts-semitexa-demo/layouts/demo-layout.html.twig' %}

{% block title %}Semitexa Demo — Framework Showcase{% endblock %}

{% set readyFeatures = featuredFeatures|default([]) %}
{% if readyFeatures is empty %}
  {% set readyFeatures = [] %}
  {% for section in sections|default([]) %}
    {% for feature in section.features|default([]) %}
      {% if readyFeatures|length < 3 %}
        {% set readyFeatures = readyFeatures|merge([feature]) %}
      {% endif %}
    {% endfor %}
  {% endfor %}
{% endif %}

{% block main %}
  {% set starterCount = starterSections|default([])|length %}
  {% set sectionCount = sections|default([])|length %}

  <section class="demo-hero">
    <div class="demo-hero__content">
      <p class="demo-hero__brand">SEMITEXA FRAMEWORK</p>
      <h1 class="demo-hero__tagline">See the framework behaving like a product, not like a brochure.</h1>
      <p class="demo-hero__lede">Routes, DI, ORM, SSR, tenancy, and async flows presented as one connected system with working entry points.</p>
      <div class="demo-hero__ctas">
        <a href="#sections" class="demo-hero__cta demo-hero__cta--primary">Explore Features</a>
        <a href="https://github.com/semitexa" class="demo-hero__cta demo-hero__cta--secondary" target="_blank" rel="noopener">View Source</a>
        <a href="/demo/get-started" class="demo-hero__cta demo-hero__cta--secondary">Get Started</a>
      </div>
      <div class="demo-hero__badges">
        <span class="demo-hero__badge">PHP 8.4 Attributes</span>
        <span class="demo-hero__badge">Swoole-native</span>
        <span class="demo-hero__badge">Zero Config</span>
      </div>
      <div
        class="demo-release-countdown"
        data-countdown
        data-countdown-target="{{ release.target }}"
      >
        <div class="demo-release-countdown__head">
          <span>{{ release.label }}</span>
          <strong>{{ release.date }}</strong>
        </div>
        <div class="demo-release-countdown__grid" aria-label="Countdown to first release">
          <div class="demo-release-countdown__unit">
            <strong data-countdown-days>--</strong>
            <span>Days</span>
          </div>
          <div class="demo-release-countdown__unit">
            <strong data-countdown-hours>--</strong>
            <span>Hours</span>
          </div>
          <div class="demo-release-countdown__unit">
            <strong data-countdown-minutes>--</strong>
            <span>Minutes</span>
          </div>
          <div class="demo-release-countdown__unit">
            <strong data-countdown-seconds>--</strong>
            <span>Seconds</span>
          </div>
        </div>
        <p class="demo-release-countdown__state" data-countdown-state>Until first release</p>
      </div>
    </div>

    <div class="demo-hero__sidecar">
      <div class="demo-hero__signal">
        <p class="demo-hero__signal-label">Live Demo Surface</p>
        <div class="demo-hero__signal-value">{{ totalFeatureCount|default(0) }}</div>
        <p class="demo-hero__signal-text">feature routes currently wired under <code>/demo</code></p>
      </div>

      <div class="demo-hero__ledger">
        <div class="demo-hero__ledger-item">
          <span class="demo-hero__ledger-value">{{ sectionCount }}</span>
          <span class="demo-hero__ledger-label">sections</span>
        </div>
        <div class="demo-hero__ledger-item">
          <span class="demo-hero__ledger-value">{{ starterCount }}</span>
          <span class="demo-hero__ledger-label">starter paths</span>
        </div>
        <div class="demo-hero__ledger-item">
          <span class="demo-hero__ledger-value">{{ readyFeatures|length }}</span>
          <span class="demo-hero__ledger-label">recommended next steps</span>
        </div>
      </div>

      <div class="demo-hero__links">
        <a
          class="demo-donate-btn"
          href="https://www.paypal.com/donate/?hosted_button_id=EWJWDP3FWH5SC"
          target="_blank"
          rel="noopener"
          title="Support Semitexa development with PayPal"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.147 6.425c-.244-1.996-1.503-3.23-3.21-3.69-1.22-.328-2.613-.306-3.834-.23-.62.039-1.238.077-1.84.077H5.694c-.58 0-1.07.417-1.166.989L2.015 18.57c-.112.664.398 1.264 1.073 1.264h3.69l-.147.886c-.085.513.31.98.829.98h3.498c.453 0 .835-.327.907-.754l1.32-7.8c.026-.153.159-.266.315-.266h.718c3.27 0 5.61-1.325 6.134-4.708.18-1.15.088-2.009-.205-2.667zm-5.758 5.645c-.28 1.76-1.764 1.76-3.14 1.76h-1.383c-.15 0-.28.113-.31.288l-.71 3.966h-1.92l1.623-9.522c.02-.124.127-.21.253-.21h1.7c1.373 0 2.227.012 2.76.262.535.25.968.682 1.103 1.54.137.86.004 1.344-.276 1.926z"/>
          </svg>
          <span>Support Semitexa</span>
        </a>
      </div>

      <div class="demo-hero__terminal">
        <p class="demo-hero__terminal-title">System framing</p>
        <ul class="demo-hero__terminal-lines">
          <li><span>$</span> browse working feature flows</li>
          <li><span>$</span> inspect source beside runtime output</li>
          <li><span>$</span> move from docs to behavior in one shell</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="demo-starters">
    <div class="demo-block-heading">
      <p class="demo-block-heading__eyebrow">Recommended Paths</p>
      <h2 class="demo-starters__heading">Start with the slices that already tell a coherent story</h2>
      <p class="demo-block-heading__text">These are the most reliable current entry points when you want to feel how Semitexa behaves as a system.</p>
    </div>
    <div class="demo-starters__grid">
      {% for section in starterSections|default([]) %}
        {% include '@project-layouts-semitexa-demo/components/feature-card.html.twig' with {
          href: section.href,
          key: section.key,
          label: section.label,
          summary: section.summary,
          icon: section.icon,
          eyebrow: section.eyebrow,
          featureCount: section.featureCount,
          prerequisites: section.prerequisites,
          starter: true,
        } only %}
      {% endfor %}
    </div>
  </section>

  <section id="sections" class="demo-sections">
    <div class="demo-block-heading">
      <p class="demo-block-heading__eyebrow">Full Map</p>
      <h2 class="demo-sections__heading">All sections <span class="demo-sections__count">{{ totalFeatureCount|default(0) }} features</span></h2>
      <p class="demo-block-heading__text">The catalog below is intentionally route-first: every card points at a live `/demo/...` entry, not a placeholder promise.</p>
    </div>
    <div class="demo-sections__grid">
      {% for section in sections|default([]) %}
        {% include '@project-layouts-semitexa-demo/components/feature-card.html.twig' with {
          href: section.href,
          key: section.key,
          label: section.label,
          summary: section.summary,
          icon: section.icon,
          eyebrow: section.eyebrow,
          featureCount: section.featureCount,
          prerequisites: section.prerequisites,
          starter: false,
        } only %}
      {% endfor %}
    </div>
  </section>

  <section class="demo-ready-prompt" data-ready-prompt style="display: none;">
    <h2 class="demo-ready-prompt__heading">Ready for more?</h2>
    <p class="demo-ready-prompt__text">These working walkthroughs are the best current entry points into the richer parts of the demo:</p>
    <div class="demo-ready-prompt__suggestions">
      {% for feature in readyFeatures %}
        <a href="{{ feature.href }}" class="demo-ready-prompt__link" {% if feature.opensInNewTab|default(false) %}target="_blank" rel="noopener"{% endif %}>{{ feature.title }}{% if feature.opensInNewTab|default(false) %}<span class="demo-link-external-indicator" aria-hidden="true">↗</span>{% endif %}</a>
      {% endfor %}
    </div>
  </section>
{% endblock %}

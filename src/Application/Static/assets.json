{
    "$schema": "semitexa://asset-manifest/v2",
    "module": "semitexa-demo",
    "include": {
        "css": ["css/**/*.css"],
        "js": ["js/**/*.js"]
    },
    "overrides": {
        "js/demo-app.js": {
            "scope": "module",
            "priority": 10,
            "attributes": { "defer": true }
        },
        "js/disclosure.js": {
            "scope": "module",
            "priority": 20,
            "attributes": { "defer": true }
        },
        "js/code-tabs.js": {
            "priority": 30,
            "attributes": { "defer": true }
        },
        "js/script-signal-card.js": {
            "priority": 31,
            "attributes": { "defer": true }
        },
        "js/api-explorer.js": {
            "scope": "module",
            "priority": 40,
            "attributes": { "defer": true }
        }
    }
}
